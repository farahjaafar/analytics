# Path to your local DuckDB database file
# This file gets created automatically on first run
DUCKDB_PATH=data/weather.duckdb

# MotherDuck token (optional, only needed for cloud deployment)
# Get yours from: https://app.motherduck.com → Settings → Access Tokens
MOTHERDUCK_TOKEN=

# Open-Meteo API base URL (no API key needed)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
